<Window x:Class="EspansoAddon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EspansoAddon"
        mc:Ignorable="d" WindowStyle="ToolWindow" Background="#a488"
        Title="Espanso Manager" Height="450" Width="500" ResizeMode="NoResize" 
		Icon="EspansoManager.ico" KeyDown="Quit" >
	
	<Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1.4*"/>
			<ColumnDefinition Width="0.5*"/> 
			<ColumnDefinition Width="0.5*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="0.3*"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="0.3*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<Border Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2"  
				BorderBrush="Aquamarine" BorderThickness="2"/>	
		<Border Grid.Column="1" Grid.Row="6" Grid.ColumnSpan="2"
				BorderBrush="Aquamarine" BorderThickness="2"/>
		<Border Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="7"
				BorderBrush="Aquamarine" BorderThickness="2"/>
		<!-- Hidden grid for the star width -->
		<Grid Grid.Column="0" Grid.RowSpan="5" Visibility="Hidden" IsHitTestVisible="False">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="5*"/>
				<ColumnDefinition Width="12*"/>
			</Grid.ColumnDefinitions>
			<Border x:Name="Col1" Grid.Column="0"/>
			<Border x:Name="Col2" Grid.Column="1"/>
		</Grid>

		<ListView  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" 
				   ScrollViewer.VerticalScrollBarVisibility="Hidden"  
				   PreviewKeyDown="DownKeyDown" PreviewKeyUp="UpKeyDown" 
				   Grid.Column="0" Grid.RowSpan="7" Name="TheList" SelectionMode="Single" >
			<!-- Gotta make the ScrollViewer bar visible but much smaller later-->
			<ListView.Resources>
				<Style TargetType="GridViewColumnHeader">
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="GridViewColumnHeader">
								<Border Background="{TemplateBinding Background}">
									<ContentPresenter />
								</Border>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Style>
			</ListView.Resources>
			<ListView.View>
				<GridView>
					<GridViewColumn 
						Header="Trigger" Width="{Binding ElementName=Col1, Path=ActualWidth}">
						<GridViewColumn.CellTemplate>
							<DataTemplate   DataType="TextBlock">
								<TextBlock Text="{Binding Trigger}" TextWrapping="Wrap" Padding="2" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
					<GridViewColumn Header="Replace" Width="{Binding ElementName=Col2, Path=ActualWidth}">
						<GridViewColumn.CellTemplate>
							<DataTemplate DataType="TextBlock">
								<TextBlock Text="{Binding Replace}" TextWrapping="Wrap" Padding="2"/>
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
				</GridView>
			</ListView.View>
		</ListView>
		<Grid Grid.Column="1" Grid.ColumnSpan="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="auto" />
			</Grid.ColumnDefinitions>
		<TextBlock Name="fileTextBlock" Foreground="AntiqueWhite"  FontWeight="Bold" FontSize="9"
                   Grid.Column="0" Grid.Row="0" Margin="5" TextWrapping="Wrap" Text="No file selected"/>

			<Button Name="fileSelect" Content="File" Click="fileSelect_Click"
                Grid.Column="2" Height="20" Width="50" Margin="5"
                VerticalAlignment="Top" HorizontalAlignment="Right"/>

		</Grid>
		<TextBlock Text="trigger" Grid.Column="1" Grid.Row="1"  
				   Margin="5 0 0 0" Foreground="DarkGray"/>
		<TextBox Name="tbTrigger" Grid.Column="1" Grid.Row="2" Margin="10 5 5 5" Grid.ColumnSpan="2"
                 VerticalContentAlignment="Center" KeyDown="tbTrigger_KeyDown"
                 Tag="Trigger" Text="{Binding TbTrigger, UpdateSourceTrigger=PropertyChanged}"/>
		<TextBlock Text="replace" Grid.Column="1" Grid.Row="3" 
				   Margin="5 0 0 0" Foreground="DarkGray"/>
		<TextBox Name="tbReplace" Grid.Column="1" Grid.Row="4" Margin="10 5 5 5" Grid.ColumnSpan="2"
                 VerticalContentAlignment="Center" KeyDown="tbReplace_KeyDown"
                 Tag="Replace" Text="{Binding TbReplace, UpdateSourceTrigger=PropertyChanged}"/>

		<Button Name="Add" Content="Add" Grid.Column="1" Grid.Row="5" Margin="10,40"
                Click="Add_Click" MinHeight="25" />

		<Button Name="Delete" Content="Delete" Grid.Column="2" Grid.Row="5" Margin="10,40"
                Click="Delete_Click" MinHeight="25"/>
		<Grid Grid.Column="1" Grid.Row="8" Grid.ColumnSpan="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="auto"/>
				<RowDefinition Height="auto"/>
				<RowDefinition Height="auto"/>
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="auto"/>
				<ColumnDefinition Width="auto" />
			</Grid.ColumnDefinitions>
			<Button Name="Up"  Click="Up_Click" Margin="2"
					Content="↑" Grid.Row="0"  Width="25" Height="20"/>
			<Button Name="Down" Click="Down_Click" Margin="2"
					Content="↓" Grid.Row="1" Width="25" Height="20"/>
			<TextBlock Text="ctrl+up key" Grid.Row="0" Grid.Column="1"
					   Foreground="DarkGray"/>
			<TextBlock Text="ctrl+down key" Grid.Row="1" Grid.Column="1" 
					   Foreground="DarkGray"/>
			<TextBlock Text="ctrl+w to quit" Grid.Row="2" Grid.Column="1" 
					   Foreground="DarkGray"/>
			
		</Grid>

	</Grid>
</Window>
