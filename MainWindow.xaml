<Window x:Class="EspansoAddon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EspansoAddon"
        mc:Ignorable="d" WindowStyle="ToolWindow" Background="#a488"
        Title="FuckRishi" Height="450" Width="500">
    <Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="0.7*"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="0.3*"/>
			<RowDefinition Height="0.3*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<ListView Grid.RowSpan="5" Name="TheList" SelectionMode="Single" >
			<ListView.View>
				<GridView >
					<GridViewColumn Header="Trigger" 
                            DisplayMemberBinding="{Binding Trigger}"/>
					<GridViewColumn Header="Replace" 
                            DisplayMemberBinding="{Binding Replace}"/>
				</GridView>
			</ListView.View>
		</ListView>
		<TextBox Name="tbTrigger" Grid.Column="1" Grid.Row="1" Margin="5"
				 Text="{Binding TbTrigger,UpdateSourceTrigger=PropertyChanged}"/>
		<TextBox Name="tbReplace" Grid.Column="1" Grid.Row="2" Margin="5"
				 Text="{Binding TbReplace,UpdateSourceTrigger=PropertyChanged}"/>
		<Button Name="Add" Content="Add" Grid.Column="1" Grid.Row="3" Margin="20 40"
		Click="Add_Click"  />
		<Button Name="Delete" Content="Delete" Grid.Column="1" Grid.Row="4" Margin="20 40"
				Click="Delete_Click"  />
	</Grid>
</Window>
