<Window x:Class="EspansoAddon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EspansoAddon"
        mc:Ignorable="d" WindowStyle="ToolWindow" Background="#a488"
        Title="FuckRishi" Height="450" Width="500">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1.4*"/>
			<ColumnDefinition Width="0.5*"/>
			<ColumnDefinition Width="0.5*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="0.3*"/>
			<RowDefinition Height="0.3*"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid Grid.Column="0" Grid.RowSpan="5" Visibility="Hidden" IsHitTestVisible="False">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<Border x:Name="Col1" Grid.Column="0"/>
			<Border x:Name="Col2" Grid.Column="1"/>
		</Grid>

		<ListView Grid.Column="0" Grid.RowSpan="5" Name="TheList" SelectionMode="Single" HorizontalContentAlignment="Stretch">
			<ListView.View>
				<GridView>
					<GridViewColumn Header="Trigger" Width="{Binding ElementName=Col1, Path=ActualWidth}"
                                    DisplayMemberBinding="{Binding Trigger}"/>
					<GridViewColumn Header="Replace" Width="{Binding ElementName=Col2, Path=ActualWidth}"
                                    DisplayMemberBinding="{Binding Replace}"/>
				</GridView>
			</ListView.View>
		</ListView>

		<TextBox Name="tbTrigger" Grid.Column="1" Grid.Row="1" Margin="5" Grid.ColumnSpan="2"
                 Text="{Binding TbTrigger, UpdateSourceTrigger=PropertyChanged}"/>
		<TextBox Name="tbReplace" Grid.Column="1" Grid.Row="2" Margin="5" Grid.ColumnSpan="2"
                 Text="{Binding TbReplace, UpdateSourceTrigger=PropertyChanged}"/>
		<Button Name="Add" Content="Add" Grid.Column="1" Grid.Row="3" Margin="20 40"
                Click="Add_Click" />
		<Button Name="Delete" Content="Delete" Grid.Column="2" Grid.Row="3" Margin="20 40"
                Click="Delete_Click" />
	</Grid>
</Window>
